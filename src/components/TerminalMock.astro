---
interface Props { compact?: boolean }
const { compact = false } = Astro.props;

const conns = [
  { name: 'vps-hetzner', target: 'root@5.75.182.x', proto: 'ssh', tag: 'prod', sel: true },
  { name: 'raspberry-pi', target: 'felipe@192.168.0.20', proto: 'ssh', tag: 'lan' },
  { name: 'nas-casa', target: 'admin@192.168.0.10', proto: 'vnc', tag: 'media' },
  { name: 'bastion-work', target: 'fnd@10.0.0.2', proto: 'rdp', tag: 'work' },
  { name: 'mileto', target: 'git@github.com', proto: 'ssh', tag: 'dev' },
];
const rows = compact ? conns.slice(0, 3) : conns;
---
<div
  class:list={['term', { compact }]}
  role="img"
  aria-label="Interfaz de julssh en la terminal: lista de conexiones SSH, RDP y VNC navegable con el teclado"
>
  <div class="bar">
    <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <span class="ttl">felipe@laptop&nbsp;—&nbsp;julssh</span>
  </div>
  <div class="screen" aria-hidden="true">
    <div class="head"><span class="brand">julssh</span><span class="sub dim">conexiones</span></div>
    <div class="filter dim">/ buscar…</div>
    <ul class="list">
      {rows.map((c) => (
        <li class:list={[{ sel: c.sel }]}>
          <span class="caret">{c.sel ? '❯' : ' '}</span>
          <span class="name">{c.name}</span>
          <span class="target dim">{c.target}</span>
          <span class:list={['proto', c.proto]}>{c.proto}</span>
          <span class="tag">[{c.tag}]</span>
        </li>
      ))}
    </ul>
    <div class="help dim">↑/↓ navegar · / filtrar · <b>c</b> conectar · <b>n</b> nueva · <b>q</b> salir</div>
  </div>
</div>

<style>
  .term {
    --t-bg: #0d0f14;
    --t-fg: #d7d3c9;
    --t-dim: #71757e;
    --t-amber: #e3a23c;
    --t-green: #84cc7f;
    --t-blue: #6ea8fe;
    --t-purple: #c08cf0;
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--t-bg);
    color: var(--t-fg);
    font-family: var(--font-mono);
    overflow: hidden;
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    flex-shrink: 0;
  }
  .dots { display: inline-flex; gap: 0.35rem; }
  .dots i { width: 0.62rem; height: 0.62rem; border-radius: 50%; background: #3a3d44; }
  .dots i:nth-child(1) { background: #e36049; }
  .dots i:nth-child(2) { background: #e3b549; }
  .dots i:nth-child(3) { background: #5fb865; }
  .ttl { font-size: 0.72rem; color: var(--t-dim); letter-spacing: 0.02em; }

  .screen { display: flex; flex-direction: column; gap: 0.5rem; padding: 0.85rem 0.95rem; font-size: 0.8rem; flex: 1; min-height: 0; }
  .head .brand { background: var(--t-amber); color: var(--t-bg); font-weight: 700; padding: 0.05rem 0.5rem; border-radius: 3px; }
  .head .sub { margin-left: 0.55rem; }
  .dim { color: var(--t-dim); }
  .filter { font-size: 0.78rem; }

  .list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.12rem; flex: 1; min-height: 0; }
  .list li { display: flex; align-items: center; gap: 0.75ch; padding: 0.18rem 0.45rem; border-radius: 4px; white-space: nowrap; overflow: hidden; }
  .caret { width: 1ch; color: var(--t-dim); }
  .name { color: var(--t-fg); }
  .target { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; }
  .proto { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .proto.ssh { color: var(--t-green); }
  .proto.rdp { color: var(--t-blue); }
  .proto.vnc { color: var(--t-purple); }
  .tag { color: var(--t-amber); opacity: 0.85; font-size: 0.74rem; }
  .list li.sel { background: rgba(227, 162, 60, 0.16); box-shadow: inset 2px 0 0 var(--t-amber); }
  .list li.sel .caret, .list li.sel .name { color: var(--t-amber); font-weight: 700; }

  .help { font-size: 0.72rem; border-top: 1px solid rgba(255, 255, 255, 0.06); padding-top: 0.5rem; flex-shrink: 0; }
  .help b { color: var(--t-fg); font-weight: 700; }

  .term.compact .bar { padding: 0.3rem 0.55rem; }
  .term.compact .screen { font-size: 0.6rem; gap: 0.32rem; padding: 0.55rem 0.6rem; }
  .term.compact .ttl { font-size: 0.6rem; }
  .term.compact .filter { font-size: 0.58rem; }
  .term.compact .help { display: none; }
</style>
