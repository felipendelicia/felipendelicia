---
import { render, type CollectionEntry } from 'astro:content';
import { useTranslations, type Locale } from '../i18n/utils';

interface Props { entry: CollectionEntry<'experiencia'>; locale: Locale }
const { entry, locale } = Astro.props;
const t = useTranslations(locale);
const { Content } = await render(entry);

const fmt = new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short' });
const hasPeriodo = entry.data.inicio != null;
const inicio = entry.data.inicio ? fmt.format(entry.data.inicio) : null;
const fin = entry.data.fin ? fmt.format(entry.data.fin) : t('experiencia.actualidad');
const vigente = hasPeriodo && entry.data.fin === null;
const subproyectos = entry.data.subproyectos;
---
<article class="exp" class:list={{ 'no-period': !hasPeriodo }}>
  {hasPeriodo && (
    <div class="period mono">
      <span class="range">{inicio} — {fin}</span>
      {vigente && <span class="now" aria-hidden="true"></span>}
    </div>
  )}
  <div class="body">
    <h3 class="role">{entry.data.rol} <span class="at">·</span> <span class="company">{entry.data.empresa}</span></h3>
    <div class="prose">
      <Content />
    </div>
    {entry.data.tags.length > 0 && (
      <ul class="tags mono">
        {entry.data.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    )}
    {subproyectos.length > 0 && (
      <div class="subproyectos">
        <h4 class="sub-label mono">{t('experiencia.desarrollos')}</h4>
        <ul class="sub-list">
          {subproyectos.map((sp) => (
            <li class="sub">
              <span class="sub-nombre">{sp.nombre}</span>
              <span class="sub-desc">{sp.descripcion}</span>
              {sp.stack.length > 0 && (
                <ul class="sub-stack mono">
                  {sp.stack.map((s) => <li>{s}</li>)}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</article>

<style>
  .exp {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .exp.no-period { grid-template-columns: 1fr; }
  .period {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: var(--step--1);
    color: var(--text-dim);
    padding-top: 0.35rem;
  }
  .now {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-soft);
    animation: pulse 2.4s ease-out infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--accent-soft); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  .role { font-size: var(--step-1); font-weight: 500; letter-spacing: -0.01em; }
  .role .at { color: var(--accent); font-family: var(--font-mono); }
  .role .company { color: var(--text-dim); }
  .body .prose { margin-top: var(--space-2); }
  .tags { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: var(--space-3); padding: 0; list-style: none; }
  .tags li {
    font-size: 0.74rem;
    letter-spacing: 0.02em;
    color: var(--text-dim);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.2rem 0.6rem;
  }

  .subproyectos { margin-top: var(--space-4); }
  .sub-label {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-faint);
    margin-bottom: var(--space-3);
  }
  .sub-list { display: grid; gap: var(--space-3); padding: 0; list-style: none; }
  .sub {
    display: grid;
    gap: 0.3rem;
    padding-left: var(--space-3);
    border-left: 1px solid var(--border);
  }
  .sub-nombre { font-size: var(--step-0); font-weight: 500; letter-spacing: -0.01em; }
  .sub-desc { color: var(--text-dim); font-size: var(--step--1); }
  .sub-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 0.15rem;
    padding: 0;
    list-style: none;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    color: var(--text-faint);
  }
  .sub-stack li { white-space: nowrap; }

  @media (max-width: 38rem) {
    .exp { grid-template-columns: 1fr; gap: var(--space-2); }
    .period { padding-top: 0; }
  }
</style>
